% Lightweight ICML-like style: two columns, Times, blue links, boxed abstract.
% Self-contained so it compiles anywhere (tectonic) without the official bundle.
\ProvidesPackage{icml_style}

\RequirePackage[letterpaper,margin=0.75in,columnsep=0.25in]{geometry}
\RequirePackage{times}
\RequirePackage{amsmath,amssymb,amsthm,bm,mathtools}
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{caption}
\RequirePackage{subcaption}
\RequirePackage{multirow}
\RequirePackage{enumitem}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{xcolor}
\RequirePackage{titlesec}

\definecolor{icmlblue}{HTML}{1F4E79}
\hypersetup{colorlinks=true, linkcolor=icmlblue, citecolor=icmlblue, urlcolor=icmlblue}

\captionsetup{font=small, labelfont=bf, skip=4pt}
\setlist{nosep, leftmargin=1.2em}

\titleformat{\section}{\large\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.5em}{}
\titlespacing*{\section}{0pt}{1.6ex}{0.7ex}
\titlespacing*{\subsection}{0pt}{1.1ex}{0.4ex}

\newtheorem{theorem}{Theorem}
\newtheorem{proposition}{Proposition}

% Math shortcuts.
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclareMathOperator*{\argmin}{arg\,min}
\DeclareMathOperator*{\argmax}{arg\,max}
\DeclareMathOperator{\rank}{rank}
\DeclareMathOperator{\spark}{spark}
\DeclareMathOperator{\STFT}{STFT}
\newcommand{\R}{\mathbb{R}}
\newcommand{\D}{\bm{D}}
\newcommand{\Mb}{\bm{M}}
\newcommand{\Yb}{\bm{Y}}
\newcommand{\Xb}{\bm{X}}
\newcommand{\Eb}{\bm{E}}
\newcommand{\xb}{\bm{x}}
\newcommand{\yb}{\bm{y}}
\newcommand{\alphab}{\bm{\alpha}}

% Abstract box.
\RequirePackage{tcolorbox}
\tcbset{abstractbox/.style={colback=icmlblue!4, colframe=icmlblue!40, boxrule=0.4pt,
        arc=2pt, left=6pt, right=6pt, top=4pt, bottom=4pt}}
